# Port (default: 3003)
PORT=3003

# Self URL — used to build the callbackUrl sent to n8n
WBB_BASE_URL=http://localhost:3003

# URL of procedures-api (internal profile)
PROCEDURES_API_URL=http://localhost:3001

# URL of case-api
CASE_API_URL=http://localhost:3002

# n8n API key and base URL
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=dev-n8n-api-key-change-in-prod

# Redis (for registry persistence)
REDIS_URL=redis://localhost:6379

# Internal secret for service-to-service communication
INTERNAL_SECRET=dev-internal-secret
