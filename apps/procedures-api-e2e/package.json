{
  "name": "@org/procedures-api-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "implicitDependencies": [
      "@org/procedures-api"
    ],
    "tags": [
      "type:app",
      "type:e2e",
      "scope:testing"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "apps/procedures-api-e2e/jest.config.cts",
          "passWithNoTests": true
        },
        "dependsOn": [
          "@org/procedures-api:build",
          "@org/procedures-api:serve"
        ]
      }
    }
  }
}
