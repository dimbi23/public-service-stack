# Database Configuration
# PostgreSQL connection string
# Format: postgres://username:password@host:port/database
DATABASE_URL=postgres://postgres@127.0.0.1:5432/torolalana

# Payload CMS Configuration
# Secret key for Payload CMS - generate a random string for production
# You can generate one with: openssl rand -base64 32
PAYLOAD_SECRET=your-secret-key-here

# Next.js Configuration
# Public URL of your application (used for generating absolute URLs)
# For local development: http://localhost:3000
# For production: https://yourdomain.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Webhook Secrets
WEBHOOK_SECRET=0Cyi22IhqORIrjyTs3WY+LgJivJMrap2tlSzf8lynTA=

# Internal service URLs (server-side only)
CASE_API_URL=http://localhost:3002
WBB_SERVICE_URL=http://localhost:3003

# Optional: Node Environment
# Set to 'production' for production deployments
NODE_ENV=development
