# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Connection strings for each app (copy to apps/<name>/.env)
# Portal  : DATABASE_URL=postgresql://postgres:postgres@localhost:5432/payload
# case-api: DATABASE_URL=postgresql://postgres:postgres@localhost:5432/case_api

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_PORT=5678
N8N_USER=admin
N8N_PASSWORD=admin123
# API key used by wbb-service to authenticate against n8n REST API
N8N_API_KEY=dev-n8n-api-key-change-in-prod
# Public URL for n8n webhooks (use ngrok or similar in dev for external callbacks)
N8N_WEBHOOK_URL=http://localhost:5678/

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
# S3 endpoint for apps
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_MEDIA=media

# ── Mailhog ───────────────────────────────────────────────────────────────────
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
# SMTP config for apps
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@taxononie.local

# ── Optional tools ────────────────────────────────────────────────────────────
REDIS_UI_PORT=8081

# ── App ports (for reference — set in each app's .env) ───────────────────────
# Portal        : 3000
# procedures-api: 3001
# case-api      : 3002
# wbb-service   : 3003
